# Docker Compose / PostgreSQL container config
POSTGRES_DB=sprintstart
POSTGRES_USER=sprintstart
POSTGRES_PASSWORD=change-me

# Crypto - Secrets Management
CRYPTO_MASTER_KEY=masterkey
CRYPTO_SALT=salt

# Docker Compose / AI Service
SPRINTSTART_AI_BASE_URL=http://host.docker.internal:8000

# Docker Compose / Keycloak Postgres config
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=change-me

# Docker Compose / Keycloak admin config
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Docker Compose / backend JWT validation config
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8081/auth/realms/sprintstart
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://keycloak:8080/auth/realms/sprintstart/protocol/openid-connect/certs

# Docker Compose / Keycloak SPI secret
SPRINTSTART_KEYCLOAK_SHARED_SECRET=change-me

# Docker Compose / keycloak connection
SPRINTSTART_KEYCLOAK_SHARED_SECRET=change-me
# SPRINTSTART_BACKEND_EVENT_URL=http://backend:8080/api/v1/internal/keycloak/events
SPRINTSTART_BACKEND_EVENT_URL=http://host.docker.internal:8080/api/v1/internal/keycloak/events
